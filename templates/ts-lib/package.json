{
	"name": "@ts-foundry-template/ts-lib",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./package.json": "./package.json"
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsdown",
		"dev": "tsdown --watch",
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"test:coverage": "vitest run --coverage",
		"pack:check": "pnpm build && publint && attw --pack .",
		"clean": "rm -rf dist coverage"
	},
	"devDependencies": {
		"@arethetypeswrong/cli": "catalog:",
		"@ts-foundry/tsconfig": "workspace:*",
		"publint": "catalog:",
		"tsdown": "catalog:",
		"typescript": "catalog:",
		"vitest": "catalog:"
	}
}
