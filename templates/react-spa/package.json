{
	"name": "@ts-foundry-template/react-spa",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "vite --host 127.0.0.1",
		"build": "tsc --noEmit && vite build",
		"preview": "vite preview",
		"typecheck": "tsc --noEmit",
		"test": "vitest run --pool=forks",
		"test:coverage": "vitest run --pool=forks --coverage",
		"e2e": "start-server-and-test \"vite --host 127.0.0.1 --port 4175\" http://127.0.0.1:4175 \"playwright test\"",
		"clean": "rm -rf dist coverage"
	},
	"dependencies": {
		"@hookform/resolvers": "catalog:",
		"@tailwindcss/vite": "catalog:",
		"@tanstack/react-query": "catalog:",
		"@tanstack/react-router": "catalog:",
		"@ts-foundry/contracts": "workspace:*",
		"@ts-foundry/ui": "workspace:*",
		"motion": "catalog:",
		"react": "catalog:",
		"react-dom": "catalog:",
		"react-hook-form": "catalog:",
		"tailwindcss": "catalog:"
	},
	"devDependencies": {
		"@playwright/test": "catalog:",
		"@testing-library/dom": "catalog:",
		"@testing-library/jest-dom": "catalog:",
		"@testing-library/react": "catalog:",
		"@testing-library/user-event": "catalog:",
		"@ts-foundry/tsconfig": "workspace:*",
		"@types/react": "catalog:",
		"@types/react-dom": "catalog:",
		"@vitejs/plugin-react": "catalog:",
		"happy-dom": "catalog:",
		"msw": "catalog:",
		"start-server-and-test": "catalog:",
		"typescript": "catalog:",
		"vite": "catalog:",
		"vitest": "catalog:"
	}
}
