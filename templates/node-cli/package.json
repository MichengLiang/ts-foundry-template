{
	"name": "@ts-foundry-template/node-cli",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"bin": {
		"ts-foundry-cli": "./dist/index.js"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./package.json": "./package.json"
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsdown",
		"dev": "tsx src/index.ts",
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"test:coverage": "vitest run --coverage",
		"clean": "rm -rf dist coverage"
	},
	"devDependencies": {
		"@ts-foundry/tsconfig": "workspace:*",
		"@types/node": "catalog:",
		"tsdown": "catalog:",
		"tsx": "catalog:",
		"typescript": "catalog:",
		"vitest": "catalog:"
	}
}
