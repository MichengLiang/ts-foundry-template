{
	"name": "@ts-foundry/api",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "tsx watch src/index.ts",
		"build": "tsdown",
		"start": "node dist/index.js",
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"test:coverage": "vitest run --coverage",
		"clean": "rm -rf dist coverage"
	},
	"dependencies": {
		"@hono/node-server": "catalog:",
		"@ts-foundry/contracts": "workspace:*",
		"hono": "catalog:",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@ts-foundry/tsconfig": "workspace:*",
		"@types/node": "catalog:",
		"tsdown": "catalog:",
		"tsx": "catalog:",
		"typescript": "catalog:",
		"vitest": "catalog:"
	}
}
